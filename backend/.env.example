# Neon connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Embedding model (384-dim)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# API runtime
HOST=0.0.0.0
PORT=8000

# Ranking weights
WEIGHT_SEMANTIC=0.6
WEIGHT_PAGERANK=0.3
WEIGHT_FRESHNESS=0.1

# Search behavior
SEARCH_CANDIDATES=50
SEARCH_LIMIT=10
