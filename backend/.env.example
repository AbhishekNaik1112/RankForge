# Copy to backend/.env and fill in DATABASE_URL. All other values have sensible
# defaults in settings.py — override only if you know why.

# Required. Neon pooled connection string (keep ?sslmode=require).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Optional. Multimodal (text + image) 512-dim CLIP model. Do not change to a
# text-only 384-dim model unless you also change schema.sql to VECTOR(384).
# EMBEDDING_MODEL=clip-ViT-B-32

# Optional. HOST and PORT are overridden by the Electron main process at
# runtime (127.0.0.1, dynamic free port). These defaults only matter if you
# run uvicorn standalone (e.g. for the seed/diag scripts).
# HOST=127.0.0.1
# PORT=8000

# Optional. Hybrid ranking weights (should sum to ~1.0).
# WEIGHT_SEMANTIC=0.5
# WEIGHT_FTS=0.2
# WEIGHT_PAGERANK=0.2
# WEIGHT_FRESHNESS=0.1

# Optional. Search behavior.
# SEARCH_CANDIDATES=50
# SEARCH_LIMIT=10
